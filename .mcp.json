{
    "mcpServers": {
        "makuco-mcp": {
			"command": "npx",
			"args": [
				"-y",
				"https://package.makuco.com.br/makuco-mcp/latest.tgz"
			],
			"env": {
                "SONAR_URL": "${SONAR_URL}",
                "SONAR_TOKEN": "${SONAR_TOKEN}"
            }
        },
        "context7": {
            "type": "http",
            "url": "https://mcp.context7.com/mcp/oauth"
        },
        "figma": {
            "type": "http",
            "url": "https://mcp.figma.com/mcp"
        }
    }
}